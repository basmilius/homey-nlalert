      "paypal": {
        "username": "basmilius"
      },
      "githubSponsors": {
        "username": "basmilius"
      }
    }
  },
  "flow": {
    "triggers": [
      {
        "id": "alert_received",
        "title": {
          "en": "NL Alert received",
          "nl": "NL Alert ontvangen"
        },
        "titleFormatted": {
          "en": "An NL Alert was received for your location",
          "nl": "Er is een NL Alert ontvangen voor jouw locatie"
        },
        "hint": {
          "en": "Fires when a new NL Alert is received that affects your Homey's location.",
          "nl": "Vuurt af wanneer er een nieuwe NL Alert is ontvangen die invloed heeft op de locatie van jouw Homey."
        },
        "tokens": [
          {
            "name": "alert_id",
            "type": "string",
            "title": {
              "en": "Alert ID",
              "nl": "Alert-ID"
            }
          },
          {
            "name": "alert_message",
            "type": "string",
            "title": {
              "en": "Alert message",
              "nl": "Alertbericht"
            }
          },
          {
            "name": "alert_start_at",
            "type": "string",
            "title": {
              "en": "Start time",
              "nl": "Starttijd"
            }
          },
          {
            "name": "alert_stop_at",
            "type": "string",
            "title": {
              "en": "End time",
              "nl": "Eindtijd"
            }
          }
        ]
      }
    ],
    "conditions": [
      {
        "id": "alert_active",
        "title": {
          "en": "An NL Alert is active",
          "nl": "Er is een actieve NL Alert"
        },
        "titleFormatted": {
          "en": "!{{An NL Alert is active for your location|No NL Alert is active for your location}}",
          "nl": "!{{Er is een actieve NL Alert voor jouw locatie|Er is geen actieve NL Alert voor jouw locatie}}"
        },
        "hint": {
          "en": "Checks if there is currently an active NL Alert affecting your Homey's location.",
          "nl": "Controleert of er momenteel een actieve NL Alert is die invloed heeft op de locatie van jouw Homey."
        }
      }
    ],
    "actions": [
      {
        "id": "get_alerts",
        "title": {
          "en": "Get active NL Alerts",
          "nl": "Haal actieve NL Alerts op"
        },
        "titleFormatted": {
          "en": "Get all active NL Alerts for your location",
          "nl": "Haal alle actieve NL Alerts op voor jouw locatie"
        },
        "hint": {
          "en": "Retrieves all currently active NL Alerts affecting your Homey's location.",
          "nl": "Haalt alle momenteel actieve NL Alerts op die invloed hebben op de locatie van jouw Homey."
        },
        "tokens": [
          {
            "name": "count",
            "type": "number",
            "title": {
              "en": "Number of alerts",
              "nl": "Aantal alerts"
            }
          },
          {
            "name": "first_message",
            "type": "string",
            "title": {
              "en": "First alert message",
              "nl": "Eerste alertbericht"
            }
          },
          {
            "name": "alerts_json",
            "type": "string",
            "title": {
              "en": "Alerts (JSON)",
              "nl": "Alerts (JSON)"
            }
          }
        ]
      }
    ]
  }
